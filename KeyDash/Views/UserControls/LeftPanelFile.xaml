<UserControl x:Class="KeyDash.Views.UserControls.LeftPanelFile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KeyDash.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Orientation="Vertical" VerticalAlignment="Center"
             HorizontalAlignment="Left" Margin="20,5">
        <StackPanel Orientation="Horizontal">
            <Label FontSize="20" Content="Выберите файл"/>
            <Button FontSize="20" Content="📁" Padding="5.2" Background="Transparent"
                BorderThickness="0"
                Command="{Binding GetFileCommand}"/>
        </StackPanel>
        <TextBlock FontSize="20" Text="{Binding Error}"/>
    </StackPanel>
</UserControl>
