<UserControl x:Class="KeyDash.Views.UserControls.StatisticPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KeyDash.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="80*"/>
        </Grid.RowDefinitions>
        <UniformGrid MaxHeight="200" Grid.Row="5" Columns="2" Rows="4">
            <Label  Content="Точность" />
            <TextBlock Text="{Binding Accuracy, StringFormat=\{0:F0\}%}"/>
            <Label Content="Процент ошибок" />
            <TextBlock Text="{Binding PercentErrors}"/>
            <Label Content="скорость" />
            <TextBlock Text="{Binding Velocity}"/>


        </UniformGrid>
        <TextBlock HorizontalAlignment="Center" FontSize="25" VerticalAlignment="Center"
                   Text="{Binding RightTime}"/>
        <Line   Style="{StaticResource OverlayStyleProgressBar}"
          VerticalAlignment="Center" Grid.Row="1" X1="0" X2="220" Y1="0"
          Y2="0" StrokeThickness="2" Stroke="Black"/>

    </Grid>
</UserControl>
