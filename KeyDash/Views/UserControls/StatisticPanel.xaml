<UserControl x:Class="KeyDash.Views.UserControls.StatisticPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KeyDash.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="800">
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="80*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80*"/>
                <ColumnDefinition Width="20*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0"  Content="Число всех ошибок" />
            <TextBlock  Grid.Row="0" Grid.Column="1"
                        HorizontalAlignment="Left" Text="{Binding TotalErrors}"/>
            <Label Grid.Row="1"  Content="Число текущих ошибок" />
            <TextBlock  Grid.Row="1" Grid.Column="1"
                       HorizontalAlignment="Left" Text="{Binding Errors}"/>
            <Label  Grid.Row="2"  Content=" Общая Точность" />
            <TextBlock Grid.Row="2" Grid.Column="1"
                       HorizontalAlignment="Left" Text="{Binding Accuracy, StringFormat=\{0:F0\} %}"/>
            <Label  Grid.Row="3"  Content=" Текущая Точность" />
            <TextBlock Grid.Row="3" Grid.Column="1"
                       HorizontalAlignment="Left" Text="{Binding NetAccuracy, StringFormat=\{0:F0\} %}"/>
            <Label  Grid.Row="4" Content="Грязная скорость в знаках" />
            <TextBlock Grid.Row="4" Grid.Column="1"
                       HorizontalAlignment="Left" Text="{Binding CPM, StringFormat=\{0:F0\} з/м}"/>
            <Label  Grid.Row="5" Content="Чистая скорость в знаках" />
            <TextBlock Grid.Row="5" Grid.Column="1"
                        HorizontalAlignment="Left" Text="{Binding NETCPM, StringFormat=\{0:F0\} з/м}"/>
            <Label  Grid.Row="6" Content="Грязная скорость в словах" />
            <TextBlock Grid.Row="6"  Grid.Column="1"
                       HorizontalAlignment="Left" Text="{Binding WPM, StringFormat=\{0:F0\} с/м}"/>
            <Label  Grid.Row="7" Content="Чистая скорость в словах" />
            <TextBlock Grid.Row="7"  Grid.Column="1"
                       HorizontalAlignment="Left" Text="{Binding NETWPM, StringFormat=\{0:F0\} с/м}"/>
        </Grid>
       
            
        <TextBlock HorizontalAlignment="Center" FontSize="25" VerticalAlignment="Center"
                   Text="{Binding RightTime, StringFormat='{}{0:mm\\:ss}'}"/>
        <Line   Style="{StaticResource OverlayStyleProgressBar}"
          VerticalAlignment="Center" Grid.Row="1" X1="0" X2="220" Y1="0"
          Y2="0" StrokeThickness="2" Stroke="Black"/>

    </Grid>
</UserControl>
