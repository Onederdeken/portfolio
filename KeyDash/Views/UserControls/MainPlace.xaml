<UserControl x:Class="KeyDash.Views.UserControls.MainPlace"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KeyDash.Views.UserControls"
             xmlns:controls="clr-namespace:KeyDash.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800"
            >
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height ="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="1" Name="TextBoxMainText" Grid.Column="1"
                   HorizontalAlignment="Center" VerticalAlignment="Center"  MaxHeight="400" 
                   TextAlignment="Justify" FontSize="30"  
                   Width="700" TextWrapping="Wrap"
                   controls:TextBlockHelper.InputText="{Binding InputText}" 
                   controls:TextBlockHelper.FullText="{Binding Text}"/>
        <Line Style="{StaticResource OverlayStyleProgressBar}" Name="ProgressLine"
              VerticalAlignment="Center" HorizontalAlignment="Center"
              Fill="Transparent" Grid.Row="0" Stroke="Black"  
              StrokeThickness= "2" X1="0" Y1="0" X2="500" Y2="0"/>
        <Button Command="{Binding DataContext.StartGame,
            RelativeSource={RelativeSource AncestorType=Window}}"
                Name="BtnStart" Grid.Row="2"
                Height="70"  Background="Transparent" BorderThickness="0"
                FontSize="35" Focusable="False" Content="Start"  />
        
    </Grid>
</UserControl>
