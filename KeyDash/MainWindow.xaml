<Window x:Class="KeyDash.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KeyDash"
        xmlns:userControls="clr-namespace:KeyDash.Views.UserControls"
        mc:Ignorable="d"
        Title="KeyDash"
        WindowState="Maximized" d:DesignHeight="630" d:DesignWidth="1120"
        WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="100*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>
           
        </Grid>
        <userControls:Topmenu/>

    </Grid>
    


</Window>
