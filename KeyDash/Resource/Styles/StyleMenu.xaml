<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:view="clr-namespace:KeyDash.Views.UserControls"
                    xmlns:mview="clr-namespace:KeyDash.ViewModels">

    <Style x:Key="MenuStyleModeFile" TargetType="MenuItem">
        <Setter Property="Padding" Value="10,5"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.GameOptions.Modes, RelativeSource={RelativeSource AncestorType=Window}}" Value="File">
                <Setter Property="Background" Value="#F0F7FF"/>
                <!-- Очень светлый голубой -->
                <Setter Property="BorderBrush" Value="#0078D7"/>
                <!-- Акцентный синий -->
                <Setter Property="BorderThickness" Value="2,0,0,0"/>
                <!-- Полоска только слева -->
                <Setter Property="FontWeight" Value="SemiBold"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="MenuStyleModeAi" TargetType="MenuItem">
        <Setter Property="Padding" Value="10.5"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.GameOptions.Modes, RelativeSource={RelativeSource AncestorType=Window}}" Value="Ai">
                <Setter Property="Background" Value="#F0F7FF"/>
                <Setter Property="BorderBrush" Value="#0078D7"/>
                <Setter Property="BorderThickness" Value="2,0,0,0"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="MenuStyleModeRandom" TargetType="MenuItem">
        <Setter Property="Padding" Value="10.5"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.GameOptions.Modes, RelativeSource={RelativeSource AncestorType=Window}}" Value="Random">
                <Setter Property="Background" Value="#F0F7FF"/>
                <Setter Property="BorderBrush" Value="#0078D7"/>
                <Setter Property="BorderThickness" Value="2,0,0,0"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>